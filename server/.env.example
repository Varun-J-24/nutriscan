PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Local auth (required for email/password login)
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# Firebase auth for Google login token verification
FIREBASE_PROJECT_ID=your_project_id

# Optional: Firebase Admin Service Account (server-side SDK mode)
# If provided, server uses firebase-admin verifyIdToken.
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
